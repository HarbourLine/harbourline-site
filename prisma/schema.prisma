generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// We only ever have one Xero connection per install for now.
// Token row holds the latest access + refresh tokens and the tenant we're connected to.
model XeroConnection {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  tenantName    String
  accessToken   String
  refreshToken  String
  expiresAt     DateTime
  scope         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Map a MyHours client (keyed by name, since MyHours' log API does not
// expose a client ID per entry) to a Xero contact (by GUID id). Optional
// per-mapping hourly rate overrides DEFAULT_HOURLY_RATE for that client.
model ClientMapping {
  id                String   @id @default(cuid())
  myHoursClientName String   @unique
  xeroContactId     String
  xeroContactName   String
  hourlyRate        Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Names to hide from the Reconcile page entirely. Applies to both sides:
// any MyHours log whose clientName matches (case-insensitive) is skipped,
// and any Xero invoice whose contact name matches is also skipped.
// Use for internal time-tracking lines, archived clients, etc.
model ExcludedName {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}
