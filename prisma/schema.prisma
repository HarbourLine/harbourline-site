generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// We only ever have one Xero connection per install for now.
// Token row holds the latest access + refresh tokens and the tenant we're connected to.
model XeroConnection {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  tenantName    String
  accessToken   String
  refreshToken  String
  expiresAt     DateTime
  scope         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Pairwise link between a MyHours client (by name) and a Xero contact
// (by GUID id). Many-to-many: one MyHours name can have multiple Xero
// contacts and vice versa. Reconcile collapses transitively-connected
// pairs into one display row to avoid double-counting.
model ClientMapping {
  id                String   @id @default(cuid())
  myHoursClientName String
  xeroContactId     String
  xeroContactName   String
  hourlyRate        Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([myHoursClientName, xeroContactId])
}

// Names to hide from the Reconcile page entirely. Applies to both sides:
// any MyHours log whose clientName matches (case-insensitive) is skipped,
// and any Xero invoice whose contact name matches is also skipped.
// Use for internal time-tracking lines, archived clients, etc.
model ExcludedName {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

// Synthetic monthly billing for clients on retainer / annual invoices.
// Attached to a MyHours client name and/or a Xero contact: the amount is
// added to that group's invoicedAmount each month within the effective range.
// If neither side links to an existing mapping group, the accrual becomes
// its own row on Reconcile.
model RecurringBilling {
  id                String   @id @default(cuid())
  name              String   // friendly display name
  amount            Float    // £ per month
  myHoursClientName String?
  xeroContactId     String?
  xeroContactName   String?
  // Inclusive YYYY-MM bounds. Null = open ended.
  effectiveFrom     String?
  effectiveTo       String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Cached reconciliation results per (year, month). Computing a month from
// scratch is slow (Xero pagination + MyHours team-wide fetch); the dashboard
// needs 6 months at once, so we cache. Re-fetched if older than 24h or via
// explicit refresh.
model ReconcileSnapshot {
  id        String   @id @default(cuid())
  year      Int
  month     Int
  data      Json     // serialized ReconcileResult
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month])
}

// Cached AI commentary for the dashboard's "anchor" month (= the last
// completed month at generation time). Invalidated when the underlying
// snapshot data hash changes, so a refreshed reconcile re-generates the
// summary.
model AISummary {
  id        String   @id @default(cuid())
  year      Int
  month     Int
  inputHash String   // sha256 of the data the summary was generated from
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month])
}
