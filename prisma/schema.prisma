generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role determines what each signed-in user can see and do. Enforced via the
// hardcoded permission matrix in src/lib/permissions.ts. OWNER (shown as
// "Founder") is bootstrapped automatically for the very first sign-in
// (Staff count == 0); every later sign-in lands as BOOKKEEPER (shown as
// "Team Member") until a Founder promotes them.
enum Role {
  OWNER
  MANAGER
  BOOKKEEPER
}

// Where a client sits in the practice lifecycle. Drives filtering in lists
// and decides which onboarding/offboarding steps apply.
enum ClientStatus {
  LEAD
  ONBOARDING
  ACTIVE
  DORMANT
  OFFBOARDED
}

// AML compliance state per client. EXPIRED triggers a re-check workflow.
enum AmlStatus {
  NOT_REQUIRED
  PENDING
  PASSED
  EXPIRED
  REJECTED
}

// The central client record — the practice's view of a real-world client.
// Subsumes the old ClientMapping concept: one Client can be referenced by
// many MyHours names and/or Xero contacts via ClientLink.
model Client {
  id                String       @id @default(cuid())
  name              String
  status            ClientStatus @default(ACTIVE)
  // Trading details
  companyNumber     String?
  vatNumber         String?
  tradingAddress    String?
  financialYearEnd  DateTime?    // day of year matters; year ignored at display time
  // Commercial
  defaultHourlyRate Float?
  accountManagerId  String?
  // AML / compliance
  amlStatus         AmlStatus    @default(NOT_REQUIRED)
  amlExpiresAt      DateTime?
  // Free-form
  notes             String?
  // Lifecycle stamps
  onboardedAt       DateTime?
  offboardedAt      DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  accountManager    Staff?       @relation("ClientsManaged", fields: [accountManagerId], references: [id])
  links             ClientLink[]
}

// Many-to-many bridge: one Client can be known to MyHours by multiple names
// and to Xero by multiple contact IDs. The unique constraint on (source,
// externalKey) prevents the same MH name or Xero contact pointing at two
// different Clients.
model ClientLink {
  id           String   @id @default(cuid())
  clientId     String
  source       String   // "myhours" | "xero"
  externalKey  String   // MH client name or Xero ContactID
  externalName String?  // display label (set for Xero contacts)
  createdAt    DateTime @default(now())

  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([source, externalKey])
  @@index([clientId])
}

// One row per practice team member. Auto-created on first sign-in (matched
// to the NextAuth Google identity by email). Stores profile fields that
// future steps (HR, holidays, AML) will surface in their own UI; for now
// only the auth-essential fields are populated.
model Staff {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  googleUserId    String?   @unique
  myHoursUserId   Int?      @unique
  role            Role      @default(BOOKKEEPER)
  isActive        Boolean   @default(true)
  // Profile fields — populated as the relevant UIs come online.
  birthday        DateTime?
  startDate       DateTime?
  leftDate        DateTime?
  jobTitle        String?
  phone           String?
  avatarUrl       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  managedClients  Client[]  @relation("ClientsManaged")
}

// We only ever have one Xero connection per install for now.
// Token row holds the latest access + refresh tokens and the tenant we're connected to.
model XeroConnection {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  tenantName    String
  accessToken   String
  refreshToken  String
  expiresAt     DateTime
  scope         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Pairwise link between a MyHours client (by name) and a Xero contact
// (by GUID id). Many-to-many: one MyHours name can have multiple Xero
// contacts and vice versa. Reconcile collapses transitively-connected
// pairs into one display row to avoid double-counting.
model ClientMapping {
  id                String   @id @default(cuid())
  myHoursClientName String
  xeroContactId     String
  xeroContactName   String
  hourlyRate        Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([myHoursClientName, xeroContactId])
}

// Names to hide from the Reconcile page entirely. Applies to both sides:
// any MyHours log whose clientName matches (case-insensitive) is skipped,
// and any Xero invoice whose contact name matches is also skipped.
// Use for internal time-tracking lines, archived clients, etc.
model ExcludedName {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

// Synthetic monthly billing for clients on retainer / annual invoices.
// Attached to a MyHours client name and/or a Xero contact: the amount is
// added to that group's invoicedAmount each month within the effective range.
// If neither side links to an existing mapping group, the accrual becomes
// its own row on Reconcile.
model RecurringBilling {
  id                String   @id @default(cuid())
  name              String   // friendly display name
  amount            Float    // £ per month
  myHoursClientName String?
  xeroContactId     String?
  xeroContactName   String?
  // Inclusive YYYY-MM bounds. Null = open ended.
  effectiveFrom     String?
  effectiveTo       String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Xero account codes whose line items are subtracted from the invoice
// total when computing "billed £". Use for pass-through charges like
// software subscriptions recharged to clients — these distort the
// effective £/hr because they're not bookkeeping revenue.
model ExcludedAccountCode {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String?  // optional human label, e.g. "Software Recharges"
  createdAt DateTime @default(now())
}

// Templates for monthly invoices that get auto-generated from MyHours logs.
// Use for clients we re-bill the same way every month (sub-client breakdown,
// fixed markup, etc.) — Urban Ledgers being the canonical example.
model InvoiceAutomation {
  id              String   @id @default(cuid())
  name            String   // friendly name, e.g. "Urban Ledgers monthly"
  xeroContactId   String   // who to bill — e.g. Urban Ledgers Ltd
  xeroContactName String
  myHoursClient   String   // MH client whose projects feed the line items
  taskFilter      String?  // optional MH task name filter (e.g. "Bookkeeping")
  projectPrefix   String?  // stripped from each project name in the line description (e.g. "UL - ")
  lineSuffix      String   @default(" - Bookkeeping Support")
  markupPercent   Float    @default(4)   // e.g. 4 = +4% over MH billable amount
  minimumLineAmount Float  @default(0)   // £ floor per line (ex VAT); 0 = no minimum
  vatRate         Float    @default(20)
  taxType         String   @default("OUTPUT2") // Xero TaxType for 20% UK output VAT
  accountCode     String   @default("200")     // Xero sales account
  // Optional Xero tracking category to set on every line item. Both must be
  // populated for tracking to be applied. Stored as names (not IDs) so the
  // setup is human-friendly — Xero matches by name on submission.
  trackingCategoryName   String?   // e.g. "Project"
  trackingCategoryOption String?   // e.g. "ASBK Ltd"
  referenceTemplate String? // optional invoice reference, supports {month} {year}
  paymentDueDays  Int      @default(30)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// MyHours users to hide from the Team page (owner, departed staff, etc.).
// Hiding only affects the /team view — these people still factor into
// client-side calculations (dashboard, reconcile, watchlist).
model ExcludedTeamMember {
  id        String   @id @default(cuid())
  userId    Int      @unique
  name      String   // captured at exclusion time for display
  createdAt DateTime @default(now())
}

// Cached output of fetchAccountCodeUsage(). Only ever one row (id="singleton")
// — we don't want to re-fetch 6 months of invoices from Xero on every visit
// to /account-exclusions. Refreshed on demand via a button; otherwise served
// from this row.
model AccountCodeDiscovery {
  id         String   @id   // always "singleton"
  data       Json         // AccountCodeUsage[]
  monthsBack Int
  fetchedAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Cached reconciliation results per (year, month). Computing a month from
// scratch is slow (Xero pagination + MyHours team-wide fetch); the dashboard
// needs 6 months at once, so we cache. Re-fetched if older than 24h or via
// explicit refresh.
model ReconcileSnapshot {
  id        String   @id @default(cuid())
  year      Int
  month     Int
  data      Json     // serialized ReconcileResult
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month])
}

// Cached AI commentary keyed by (type, year, month). "type" discriminates
// between the dashboard's firm-level summary and the team page's per-person
// summary. Invalidated when the underlying snapshot data hash changes, so a
// refreshed reconcile re-generates the relevant summaries.
model AISummary {
  id        String   @id @default(cuid())
  type      String   @default("dashboard") // "dashboard" | "team"
  year      Int
  month     Int
  inputHash String   // sha256 of the data the summary was generated from
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, year, month])
}
