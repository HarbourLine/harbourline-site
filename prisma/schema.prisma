generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// We only ever have one Xero connection per install for now.
// Token row holds the latest access + refresh tokens and the tenant we're connected to.
model XeroConnection {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  tenantName    String
  accessToken   String
  refreshToken  String
  expiresAt     DateTime
  scope         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Pairwise link between a MyHours client (by name) and a Xero contact
// (by GUID id). Many-to-many: one MyHours name can have multiple Xero
// contacts and vice versa. Reconcile collapses transitively-connected
// pairs into one display row to avoid double-counting.
model ClientMapping {
  id                String   @id @default(cuid())
  myHoursClientName String
  xeroContactId     String
  xeroContactName   String
  hourlyRate        Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([myHoursClientName, xeroContactId])
}

// Names to hide from the Reconcile page entirely. Applies to both sides:
// any MyHours log whose clientName matches (case-insensitive) is skipped,
// and any Xero invoice whose contact name matches is also skipped.
// Use for internal time-tracking lines, archived clients, etc.
model ExcludedName {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}
