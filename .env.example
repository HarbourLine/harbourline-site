# Copy to .env.local and fill in. Never commit .env.local.

# ---- Database (Postgres) ----
# Local dev and production both point at the same Neon Postgres DB.
# Get the URL from your Neon project → Dashboard → Connection string.
# Must include ?sslmode=require.
DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# ---- NextAuth (Google sign-in) ----
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=
# Google Cloud Console → APIs & Services → Credentials → OAuth client (Web)
# Authorized redirect URI: <BASE_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Lock sign-in to this Google Workspace domain. Leave blank to allow any
# Google account (not recommended).
ALLOWED_GOOGLE_DOMAIN=asbookkeepingservices.com

# ---- Xero OAuth 2.0 ----
# Create app at https://developer.xero.com → My Apps → New app
# Integration type: Web app
# Redirect URIs to register (add both):
#   - http://localhost:3000/api/xero/callback
#   - https://asbk-reconcile.vercel.app/api/xero/callback
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3000/api/xero/callback

# ---- MyHours ----
# Get from MyHours web app → profile → Integrations / API
# Personal API token (sent as `Authorization: apikey <token>`)
MYHOURS_API_KEY=

# ---- App ----
# Used to sign Xero OAuth `state` to prevent CSRF. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=

# ---- Anthropic (Claude — optional, for dashboard AI analysis) ----
# Sign up at https://console.anthropic.com (separate from claude.ai Max plan).
# Settings → API Keys → Create Key. Without it, the dashboard's "Analysis"
# section is hidden; everything else works.
ANTHROPIC_API_KEY=
