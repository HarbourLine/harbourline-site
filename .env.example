# Copy to .env.local and fill in. Never commit .env.local.

# ---- Xero OAuth 2.0 ----
# Create app at https://developer.xero.com → My Apps → New app
# Integration type: Web app
# Redirect URI (dev): http://localhost:3000/api/xero/callback
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3000/api/xero/callback

# ---- MyHours ----
# Get from MyHours web app → profile → Integrations / API
# Personal API token (sent as `Authorization: apikey <token>`)
MYHOURS_API_KEY=

# ---- App ----
# Used to sign Xero OAuth `state` to prevent CSRF. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=

# Optional: default hourly rate used when a client mapping has no rate set.
# Used to compute "implied $" from tracked hours when no per-client rate exists.
DEFAULT_HOURLY_RATE=150

# Note: DATABASE_URL is set in the committed `.env` file (file:./dev.db).
# Don't add it here — overriding it will desync the path Prisma CLI uses vs runtime.
